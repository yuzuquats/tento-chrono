{
  "extends": "../yuzu-js/tsconfig.base.json",
  "compilerOptions": {
    "typeRoots": [
      "../yuzu-js/ui/types/*.d.ts"
    ],
    "isolatedModules": false,
    "paths": {
      "@lona/*": [
        "../yuzu-js/ui/*"
      ],
      "@tento-chrono": [
        "./chrono/mod.ts"
      ],
      "@tento-chrono/*": [
        "./*"
      ],
      "@tento/chrono": [
        "./chrono/mod.ts"
      ],
      "@tento/chrono/*": [
        "./*"
      ]
    }
  },
  "include": [
    "**/*.ts",
    "../yuzu-js/ui/types/*.d.ts"
  ]
}
